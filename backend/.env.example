# ════════════════════════════════════════════════════════════════
# AutoTradeX Backend — 환경변수 설정 가이드
# ════════════════════════════════════════════════════════════════
#
# 사용법:
#   1. 이 파일을 복사해서 .env 로 저장
#      cp .env.example .env
#
#   2. 아래 "직접 입력 필요" 항목들을 채워주세요
#
#   3. .env 는 절대 git에 커밋하지 마세요 (.gitignore 확인)
#
# ════════════════════════════════════════════════════════════════


# ── 서버 기본 ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # development | production
TZ=Asia/Seoul
CORS_ORIGIN=http://localhost:5060


# ── JWT / 암호화 키 (직접 입력 필요) ──────────────────────────
#
# ⚠️  이 값들은 절대 외부에 공개하지 마세요.
# ⚠️  한 번 설정하면 변경 시 기존 토큰/데이터가 모두 무효화됩니다.
#
# 생성 방법 (터미널):
#   node -e "const c=require('crypto'); console.log(c.randomBytes(64).toString('hex'))"
#   → 128자 hex 문자열 → JWT_SECRET 에 입력
#
#   node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('hex'))"
#   → 64자 hex 문자열 → ENCRYPTION_SECRET 에 입력
#
JWT_SECRET=여기에_128자_hex_문자열_입력
JWT_EXPIRES_IN=24h
ENCRYPTION_SECRET=여기에_64자_hex_문자열_입력
PASSWORD_PEPPER=여기에_48자_hex_문자열_입력
SYSTEM_ENCRYPTION_SECRET=ENCRYPTION_SECRET_과_동일값_입력


# ── 데이터베이스 ───────────────────────────────────────────────
#
# SQLite 파일 경로 (상대경로 OK)
# 계좌 정보(AppKey/AppSecret)는 DB에 AES-256-GCM 암호화 저장됩니다.
# → .env 에 KIS 계좌 정보를 넣지 않아도 됩니다.
#
DATABASE_PATH=./data/autotradex.db


# ── 한국투자증권 KIS API ───────────────────────────────────────
#
# ⚠️  계좌별 AppKey/AppSecret은 DB에 암호화 저장됩니다.
#     (앱 내 "매매 설정 → 1단계 계좌 연결" 에서 입력)
#
# 아래는 서버 기본 도메인 설정만 관리합니다.
# (변경할 일 거의 없음)
#
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_MOCK_URL=https://openapivts.koreainvestment.com:29443


# ── AI 분석 엔진 ───────────────────────────────────────────────
#
# AI_PROVIDER 값에 따라 사용할 AI가 결정됩니다.
#
# [현재 지원]
#   genspark  → Genspark API (OpenAI 호환)
#   mock      → 목업 응답 (개발/테스트용, API 키 불필요)
#
# [Genspark API 키 발급 방법]
#   1. https://www.genspark.ai 로그인
#   2. 우상단 프로필 → Settings → API Keys
#   3. "Create new key" 클릭 → 키 복사
#   4. 아래 GENSPARK_API_KEY 에 붙여넣기
#
# [API 엔드포인트]
#   Genspark는 OpenAI 호환 형식을 사용합니다.
#   Base URL: https://api.genspark.ai/v1
#   모델명:   genspark-moa-1   (최신 복합 AI)
#
AI_PROVIDER=mock
GENSPARK_API_KEY=여기에_Genspark_API_키_입력
GENSPARK_BASE_URL=https://api.genspark.ai/v1
GENSPARK_MODEL=genspark-moa-1


# ── 매매 안전장치 ──────────────────────────────────────────────
#
# 이 값들은 앱 내 "매매 설정"에서도 개별 조정 가능합니다.
# 여기서는 서버 전체 기본값(하드 리밋)을 설정합니다.
#
TRADING_MODE=paper                  # paper(가상) | live(실전)
MAX_DAILY_LOSS_RATE=-0.05           # 일일 최대 손실률 -5%
MAX_POSITION_RATIO=0.30             # 종목당 최대 비중 30%
MAX_CONCURRENT_POSITIONS=3          # 동시 최대 보유 종목 수
MIN_CASH_RESERVE=0.20               # 최소 현금 보유 비율 20%
STOP_LOSS_THRESHOLD=-0.03           # 단일 종목 강제 손절 -3%
MAX_CONSECUTIVE_LOSSES=3            # 연속 손실 허용 횟수
CIRCUIT_BREAKER_COOLDOWN=1800       # 서킷브레이커 쿨다운 (초)


# ── 알림 (선택 사항) ───────────────────────────────────────────
#
# 텔레그램 봇으로 거래 알림을 받을 수 있습니다.
# 봇 만들기: https://t.me/BotFather → /newbot
# Chat ID 확인: https://t.me/userinfobot
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
