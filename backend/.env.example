# ════════════════════════════════════════════════════════════════
# AutoTradeX Backend — 환경변수 설정 가이드
# ════════════════════════════════════════════════════════════════
#
# 사용법:
#   1. 이 파일을 복사해서 .env 로 저장
#      cp .env.example .env
#
#   2. 아래 "직접 입력 필요" 항목들을 채워주세요
#
#   3. .env 는 절대 git에 커밋하지 마세요 (.gitignore 확인)
#
# ════════════════════════════════════════════════════════════════


# ── 서버 기본 ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # development | production
TZ=Asia/Seoul
CORS_ORIGIN=http://localhost:5060


# ── JWT / 암호화 키 (직접 입력 필요) ──────────────────────────
#
# ⚠️  이 값들은 절대 외부에 공개하지 마세요.
# ⚠️  한 번 설정하면 변경 시 기존 토큰/데이터가 모두 무효화됩니다.
#
# 생성 방법 (터미널):
#   node -e "const c=require('crypto'); console.log(c.randomBytes(64).toString('hex'))"
#   → 128자 hex 문자열 → JWT_SECRET 에 입력
#
#   node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('hex'))"
#   → 64자 hex 문자열 → ENCRYPTION_SECRET 에 입력
#
JWT_SECRET=여기에_128자_hex_문자열_입력
JWT_EXPIRES_IN=24h
ENCRYPTION_SECRET=여기에_64자_hex_문자열_입력
PASSWORD_PEPPER=여기에_48자_hex_문자열_입력
SYSTEM_ENCRYPTION_SECRET=ENCRYPTION_SECRET_과_동일값_입력


# ── 데이터베이스 ───────────────────────────────────────────────
#
# SQLite 파일 경로 (상대경로 OK)
# 계좌 정보(AppKey/AppSecret)는 DB에 AES-256-GCM 암호화 저장됩니다.
# → .env 에 KIS 계좌 정보를 넣지 않아도 됩니다.
#
DATABASE_PATH=./data/autotradex.db


# ── 한국투자증권 KIS API ───────────────────────────────────────
#
# ⚠️  계좌별 AppKey/AppSecret은 DB에 암호화 저장됩니다.
#     (앱 내 "매매 설정 → 1단계 계좌 연결" 에서 입력)
#
# 아래는 서버 기본 도메인 설정만 관리합니다.
# (변경할 일 거의 없음)
#
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_MOCK_URL=https://openapivts.koreainvestment.com:29443


# ── AI 분석 엔진 ───────────────────────────────────────────────
#
# AI_PROVIDER: openai | mock
#   openai → OpenAI API 직접 사용
#   mock   → 목업 응답 (개발/테스트용, API 키 불필요)
#
# [OpenAI API 키 발급]
#   https://platform.openai.com → API Keys → Create new secret key
#
# [모델 추천]
#   gpt-4o-mini  → 빠르고 저렴, 분석 정확도 충분 (권장)
#   gpt-4o       → 최고 정확도, 비용 높음
#
AI_PROVIDER=mock
OPENAI_API_KEY=여기에_OpenAI_API_키_입력
OPENAI_MODEL=gpt-4o-mini


# ── 매매 안전장치 ──────────────────────────────────────────────
#
# 이 값들은 앱 내 "매매 설정"에서도 개별 조정 가능합니다.
# 여기서는 서버 전체 기본값(하드 리밋)을 설정합니다.
#
TRADING_MODE=paper
MAX_DAILY_LOSS_RATE=-0.05
MAX_POSITION_RATIO=0.30
MAX_CONCURRENT_POSITIONS=3
MIN_CASH_RESERVE=0.20
STOP_LOSS_THRESHOLD=-0.03
MAX_CONSECUTIVE_LOSSES=3
CIRCUIT_BREAKER_COOLDOWN=1800

