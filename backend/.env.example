# ============================================================
# AutoTradeX 백엔드 환경변수 설정 가이드
# 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
# cp .env.example .env
# ============================================================

# ────────────────────────────────────────
# [1] 서버 기본 설정
# ────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | staging | production
TZ=Asia/Seoul

# Flutter 웹 앱 주소 (CORS 허용 대상)
# 로컬 개발: http://localhost:5060
# 배포 후: https://your-domain.com
CORS_ORIGIN=http://localhost:5060

# ────────────────────────────────────────
# [2] JWT 시크릿 키
# 얻는 방법: 터미널에서 아래 명령어 실행
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 또는 https://generate-secret.vercel.app/64 에서 생성
# ⚠️ 절대 공유하지 말 것, 유출 시 즉시 교체
# ────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=24h

# ────────────────────────────────────────
# [3] 암호화 마스터 시크릿 (API Key 암호화용)
# 얻는 방법: JWT_SECRET과 동일하게 별도 생성
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ────────────────────────────────────────
ENCRYPTION_SECRET=REPLACE_WITH_32_CHAR_RANDOM_HEX_STRING

# 비밀번호 해싱 페퍼 (추가 보안 레이어)
# 얻는 방법: 위와 동일하게 랜덤 문자열 생성
PASSWORD_PEPPER=REPLACE_WITH_RANDOM_PEPPER_STRING

# ────────────────────────────────────────
# [4] 데이터베이스 (SQLite - 로컬 개발용)
# 별도 설치 불필요, 경로만 지정하면 자동 생성됨
# ────────────────────────────────────────
DATABASE_PATH=./data/autotradex.db

# PostgreSQL (운영 환경용 - 개발 시 주석 처리)
# 얻는 방법:
#   - Supabase(무료): https://supabase.com → 프로젝트 생성 → Settings → Database → Connection string
#   - Neon(무료): https://neon.tech → 프로젝트 생성 → Dashboard → Connection string
#   - Railway: https://railway.app → New Project → PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/autotradex

# ────────────────────────────────────────
# [5] 키움증권 REST API
# 얻는 방법:
#   1. https://openapi.kiwoom.com 접속
#   2. 로그인 → 마이페이지 → API 관리
#   3. 앱 등록 (서비스명, 설명 입력)
#   4. 등록 완료 후 App Key + App Secret 발급
#   ⚠️ 모의투자 계좌로 먼저 테스트 필수!
#   ⚠️ 실계좌 사용 전 최소 2주 모의투자 검증
# ────────────────────────────────────────
KIWOOM_APP_KEY=your_kiwoom_app_key
KIWOOM_APP_SECRET=your_kiwoom_app_secret
KIWOOM_ACCOUNT_NO=your_account_number  # 계좌번호 (예: 1234567890)
KIWOOM_BASE_URL=https://openapi.kiwoom.com
# 모의투자 URL (개발/테스트용)
KIWOOM_MOCK_URL=https://openapivts.kiwoom.com
KIWOOM_IS_MOCK=true   # true=모의투자, false=실투자

# ────────────────────────────────────────
# [6] 한국투자증권 KIS API (2순위)
# 얻는 방법:
#   1. https://apiportal.koreainvestment.com 접속
#   2. 회원가입 → 앱 등록
#   3. APP Key + APP Secret 발급
#   ⚠️ WebSocket 무한루프 자동 차단 정책 주의
# ────────────────────────────────────────
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NO=your_account_number
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# 모의투자 URL
KIS_MOCK_URL=https://openapivts.koreainvestment.com:29443
KIS_IS_MOCK=true

# ────────────────────────────────────────
# [7] AI 모델 (Genspark / Claude / GPT)
# 얻는 방법 (택1):
#   - Anthropic Claude: https://console.anthropic.com → API Keys → Create Key
#   - OpenAI GPT: https://platform.openai.com → API Keys → Create new secret key
#   - Genspark: Genspark AI Developer 환경 내장 (별도 키 불필요)
# ────────────────────────────────────────
AI_PROVIDER=genspark           # genspark | anthropic | openai
AI_MODEL=claude-sonnet-4       # claude-sonnet-4 | gpt-4o | gpt-4-turbo

# Anthropic 사용 시
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# OpenAI 사용 시
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# ────────────────────────────────────────
# [8] 텔레그램 알림 봇 (선택)
# 얻는 방법:
#   1. 텔레그램에서 @BotFather 검색
#   2. /newbot 명령어 → 봇 이름 입력
#   3. Token 발급됨 (예: 123456:ABC-DEF...)
#   4. Chat ID 얻기: 봇에게 메시지 전송 후
#      https://api.telegram.org/bot{TOKEN}/getUpdates 호출
#      → result[0].message.chat.id 값
# ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ────────────────────────────────────────
# [9] 매매 설정 (안전장치)
# ────────────────────────────────────────
TRADING_MODE=paper             # paper=모의투자, live=실투자
MAX_DAILY_LOSS_RATE=-0.05      # 일일 최대 손실률 (-5%)
MAX_POSITION_RATIO=0.30        # 단일 종목 최대 비중 (30%)
MAX_CONCURRENT_POSITIONS=3     # 최대 동시 보유 종목 수
MIN_CASH_RESERVE=0.20          # 최소 현금 보유 비율 (20%)
STOP_LOSS_THRESHOLD=-0.03      # 손절 기준 (-3%)
MAX_CONSECUTIVE_LOSSES=3       # 연속 손절 허용 횟수
CIRCUIT_BREAKER_COOLDOWN=1800  # 서킷브레이커 대기 시간 (초)
